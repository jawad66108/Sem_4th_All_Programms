.data
num:    .word 0
result: .word 0
prompt: .asciiz "Enter an integer: "
msg:    .asciiz "The square is: "

.text
.globl main

main:
    li $v0, 4
    la $a0, prompt
    syscall

    li $v0, 5
    syscall
    sw $v0, num

    lw $a0, num
    jal square

    sw $v0, result

    li $v0, 4
    la $a0, msg
    syscall

    li $v0, 1
    lw $a0, result
    syscall

    li $v0, 10
    syscall

square:
    mul $v0, $a0, $a0
    jr $ra
